   "source": [
    "from pyspark.sql.window import Window\n",
    "from pyspark.sql.functions import col, row_number, sum\n",
    "\n",
    "# Step 1: Join with cars table (sales_clean already has customer data from Cell 28)\n",
    "df = sales_clean.join(cars_clean, \"car_id\", \"left\")\n",
    "\n",
    "# Step 2: Aggregate total spending per customer per city\n",
    "df_agg = df.groupBy(\"city\", \"customer_id\") \\\n",
    "           .agg(sum(\"price\").alias(\"total_spent\"))\n",
    "\n",
    "# Step 3: Define window (partition by city)\n",
    "window_spec = Window.partitionBy(\"city\").orderBy(col(\"total_spent\").desc())\n",
    "\n",
    "# Step 4: Apply row_number\n",
    "df_ranked = df_agg.withColumn(\"rank\", row_number().over(window_spec))\n",
    "\n",
    "# Step 5: Get Top 3 per city\n",
    "df_ranked.filter(col(\"rank\") <= 3).show()"
